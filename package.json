    "lint:remark": "remark . --quiet",
    "lint:secretlint": "secretlint \"**/*\"",
    "lint:stylelint": "stylelint \"**/*.css\"",
    "lint:textlint": "textlint \"**/*.{md,mdx}\"",
    "preinstall": "npx only-allow pnpm",
    "prepare": "lefthook install"
