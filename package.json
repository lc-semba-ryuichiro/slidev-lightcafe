    "browserslist": "catalog:",
    "lefthook": "catalog:",
    "remark": "catalog:",
    "remark-cli": "catalog:",
    "remark-frontmatter": "catalog:",
    "remark-gfm": "catalog:",
    "remark-lint": "catalog:",
    "remark-preset-lint-consistent": "catalog:",
    "remark-preset-lint-recommended": "catalog:",
    "remark-toc": "catalog:",
    "secretlint": "catalog:",
    "stylelint": "catalog:",
    "textlint": "catalog:",
    "textlint-filter-rule-allowlist": "catalog:",
    "textlint-filter-rule-comments": "catalog:",
